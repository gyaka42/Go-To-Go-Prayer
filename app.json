{
  "expo": {
    "name": "GoToGo Pray",
    "slug": "go-to-go-prayer",
    "scheme": "gotogoprayer",
    "icon": "./assets/images/Light/AppIcon~ios-marketing.png",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "sounds": ["./assets/sounds/adhan_short.wav"]
        }
      ]
    ],
    "ios": {
      "icon": {
        "light": "./assets/images/Light/AppIcon~ios-marketing.png",
        "dark": "./assets/images/Dark/AppIcon~ios-marketing.png"
      },
      "buildNumber": "55",
      "supportsTablet": true,
      "bundleIdentifier": "com.gogo22.gotogoprayer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used to calculate accurate prayer times, Qibla direction, and nearby mosques.",
        "NSUserNotificationsUsageDescription": "Notifications are used to remind you of prayer times.",
        "LSApplicationQueriesSchemes": ["comgooglemaps"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "229fd9a3-2505-4801-9e23-a988563d72f1"
      }
    }
  }
}
